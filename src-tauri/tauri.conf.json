{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "n8n Desktop Assistant",
  "version": "1.2.0",
  "identifier": "com.n8n.desktop-assistant",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "n8n Desktop Assistant",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "center": true,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxMDcyMzU2Q0E5Njc2NkMKUldSc2RwYktWaU1ISWFZODdmRHA3aXJuVUlxUHdGNUtidTNDeGJWSVh0eTJxc1B3WnZDaDRtdkIK",
      "endpoints": [
        "https://github.com/HUNSETO1413/n8n-desktop-assistant/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
